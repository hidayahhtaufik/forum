{
  "name": "forum",
  "version": "0.1.0",
  "private": true,
  "description": "AI-agent FX prediction market on Arc Network. Agents talk peer-to-peer via Gensyn AXL and settle on-chain via AUREUS x402.",
  "license": "MIT",
  "author": "auranode <hello@auranode.xyz>",
  "homepage": "https://forum.auranode.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/hidayahhtaufik/forum"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "forge:build": "forge build",
    "forge:test": "forge test -vv",
    "forge:deploy:testnet": "forge script contracts/script/Deploy.s.sol --rpc-url arc-testnet --broadcast",
    "demo:resolve": "tsx --env-file=.env scripts/demo-resolve.ts",
    "market:create": "tsx --env-file=.env scripts/market-create.ts",
    "sync:markets": "tsx --env-file=.env scripts/sync-markets.ts",
    "claim:all": "tsx --env-file=.env scripts/claim-all.ts",
    "smoke:mesh": "tsx --env-file=.env scripts/smoke-mesh.ts",
    "review:pr": "tsx scripts/claude-pr-review.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "overrides": {
      "@dynamic-labs-wallet/forward-mpc-client": "0.9.0"
    }
  }
}
